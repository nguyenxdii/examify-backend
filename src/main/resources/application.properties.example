spring.application.name=examify-backend
server.port=8080

# MongoDB
spring.data.mongodb.uri=mongodb+srv://<username>:<password>@cluster.mongodb.net/examify?retryWrites=true&w=majority
spring.data.mongodb.database=examify

# JWT
jwt.secret=your_jwt_secret_here
jwt.expiration=86400000

# Cloudinary
cloudinary.cloud-name=your_cloud_name
cloudinary.api-key=your_api_key
cloudinary.api-secret=your_api_secret

# Gemini
gemini.api-keys=your_gemini_api_key1,your_gemini_api_key2